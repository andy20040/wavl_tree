#!/usr/bin/env bpftrace


tracepoint:sched:sched_switch
{
    @events["Scheduler (CFS)"] = count();
}

tracepoint:timer:hrtimer_start
{
    @events["High-Res Timers"] = count();
}


tracepoint:exceptions:page_fault_user
{
    @events["VMA (Page Faults)"] = count();
}


interval:s:5
{
    printf("\n=== System Subsystem Event Distribution ===\n");
    print(@events);
    clear(@events);
}