#include <linux/sched.h>

BEGIN {
    printf("Recording CFS True RB-Tree Operations... Hit Ctrl-C to stop.\n");
}

kprobe:__enqueue_entity {
    // arg1 : struct sched_entity *se
    $se = (struct sched_entity *)arg1;
    printf("I %llu\n", $se->vruntime);
}

kprobe:__dequeue_entity {
    // arg1 : struct sched_entity *se
    $se = (struct sched_entity *)arg1;
    printf("D %llu\n", $se->vruntime);
}